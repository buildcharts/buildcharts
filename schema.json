{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://buildcharts.dev/schemas/build.schema.json",
  "title": "BuildCharts build.yml",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string"
    },
    "variables": {
      "oneOf": [
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "null"]
          }
        }
      ]
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "targets": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/targetEntry"
      }
    }
  },
  "required": ["targets"],
  "$defs": {
    "targetEntry": {
      "oneOf": [
        {"type": "string"},
        {"$ref": "#/$defs/targetDefinition"},
        {
          "type": "array",
          "items": {"$ref": "#/$defs/targetItem"}
        }
      ]
    },
    "targetItem": {
      "oneOf": [
        {"type": "string"},
        {"$ref": "#/$defs/targetDefinition"}
      ]
    },
    "targetDefinition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "oneOf": [
            {"type": "string"},
            {
              "type": "array",
              "items": {"type": "string"},
              "minItems": 1
            }
          ]
        },
        "with": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": ["type"]
    }
  }
}
